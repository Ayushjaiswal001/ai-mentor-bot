# Application
APP_NAME="PathwayAI Tutor"
APP_ENV="development"
APP_HOST="0.0.0.0"
APP_PORT=8000
APP_BASE_URL="http://127.0.0.1:8000"
LOG_LEVEL="INFO"
USER_TIMEZONE="Asia/Kolkata"
DEFAULT_USER_NAME="Ayush"
TARGET_ROLE="Backend / AI Engineer"
JOB_SEARCH_HORIZON_MONTHS=6

# Neon PostgreSQL
# Use Neon's pooled connection string. Never use production credentials in tests.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/neondb?sslmode=require"
# Optional direct Neon connection recommended for Alembic migrations.
MIGRATION_DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Internal GitHub Actions trigger authentication
INTERNAL_TRIGGER_SECRET="replace-with-a-long-random-secret"

# Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_API_BASE="https://api.telegram.org"

# GitHub activity
GITHUB_USERNAME=""
GITHUB_TOKEN=""
GITHUB_API_BASE="https://api.github.com"

# LeetCode activity
LEETCODE_USERNAME=""
LEETCODE_SESSION=""
LEETCODE_CSRF_TOKEN=""
LEETCODE_GRAPHQL_URL="https://leetcode.com/graphql"

# Models: Groq is primary, Hugging Face is fallback.
GROQ_API_KEY=""
GROQ_MODEL="openai/gpt-oss-20b"
HUGGINGFACE_API_TOKEN=""
HUGGINGFACE_MODEL="Qwen/Qwen2.5-7B-Instruct"
HUGGINGFACE_PROVIDER="auto"
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=1200
MODEL_TIMEOUT_SECONDS=45

# LangSmith is optional. LangGraph still runs when disabled.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="pathwayai"
LOCAL_TRACE_PATH="var/traces.jsonl"
RAW_EVENT_RETENTION_DAYS=365
RAW_MESSAGE_RETENTION_DAYS=180

# Weekly digest email. Off until SMTP_HOST and DIGEST_EMAIL_TO are both set.
# Port 465 = implicit TLS, anything else = STARTTLS. For Gmail use an app
# password (https://myaccount.google.com/apppasswords), not your real password.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USERNAME=""
SMTP_PASSWORD=""
DIGEST_EMAIL_FROM=""
DIGEST_EMAIL_TO=""

# Mentor behavior
TUTOR_NAME="PathwayAI"
TUTOR_DEFAULT_GOAL="Become interview-ready for a backend or AI engineering role within six months."
MAX_INTERVIEW_FOLLOWUPS=3
