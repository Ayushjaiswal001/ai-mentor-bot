# Telegram
TELEGRAM_BOT_TOKEN=
ALLOWED_TG_USER_IDS=            # your numeric Telegram user id (comma-separated if several)

# LLM providers
GEMINI_API_KEY=
GROQ_API_KEY=                   # optional fallback
OPENAI_API_KEY=                 # optional

# Model tiers (provider:model) — change without touching code
LLM_T0=gemini:gemini-2.0-flash-lite
LLM_T1=gemini:gemini-2.5-flash
LLM_T2=gemini:gemini-2.5-pro

# Budget guards (LLM calls per day)
DAILY_T1_CAP=30
DAILY_T2_CAP=6
FREETEXT_DAILY_CAP=15

# Data & runtime
DATABASE_URL=sqlite+aiosqlite:///./data/mentor.db
MODE=polling                    # polling | webhook
ADMIN_TOKEN=
WEBHOOK_SECRET=
